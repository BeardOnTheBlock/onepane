# ============================================================================
# OnePane configuration — copy this file to `.env` and fill in the values.
#   cp .env.example .env
# ============================================================================

# ----------------------------------------------------------------------------
# Local database (SQLite). The default keeps your data inside the repo folder.
# This file holds your ENCRYPTED OAuth tokens and is git-ignored — never commit it.
# ----------------------------------------------------------------------------
DATABASE_URL="file:./onepane.db"

# ----------------------------------------------------------------------------
# Encryption key used to encrypt OAuth tokens at rest (AES-256-GCM).
# Generate one with:   openssl rand -base64 32
# If this changes, previously connected accounts must be re-connected.
# ----------------------------------------------------------------------------
ONEPANE_ENCRYPTION_KEY=""

# ----------------------------------------------------------------------------
# Where the app is served. Used to build OAuth redirect URIs.
# Leave as-is for local development.
# ----------------------------------------------------------------------------
APP_URL="http://localhost:6969"

# ----------------------------------------------------------------------------
# Google OAuth (Gmail + Google Calendar + Google Meet)
# OPTIONAL: you can instead add the Client ID & Secret in the app under
#   Settings → Set up Google (stored encrypted in the local database, not a file).
# Set them here only if you prefer environment configuration.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI:  http://localhost:6969/api/connect/google/callback
# See docs/OAUTH_SETUP.md for the full walkthrough.
# ----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ----------------------------------------------------------------------------
# Microsoft OAuth (Outlook Mail + Calendar + Teams) via Microsoft Graph
# Register an app at https://entra.microsoft.com (App registrations).
# Redirect URI (type "Web"):  http://localhost:6969/api/connect/microsoft/callback
# Use the "common" tenant so both work and personal accounts can connect.
# See docs/OAUTH_SETUP.md for the full walkthrough.
# ----------------------------------------------------------------------------
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT="common"
