// OnePane hosted (multi-user) database schema.
// Postgres for multi-tenant use; every connected mailbox/calendar is owned by a
// User. OAuth/IMAP tokens are encrypted at rest (AES-256-GCM) by the app layer
// before they are written here.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// An app user (created on first "Sign in with Google"). Identity only.
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  image     String?
  createdAt DateTime  @default(now())
  accounts  Account[]
}

// A connected email/calendar account, owned by exactly one User.
model Account {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider    String // "google" | "microsoft" | "imap"
  email       String
  displayName String?
  color       String  @default("#6366f1")
  canTeams    Boolean @default(false)
  canMeet     Boolean @default(false)

  // --- Encrypted secrets (AES-256-GCM, "iv:tag:ciphertext" base64) ---
  accessToken  String
  refreshToken String?

  tokenExpiry DateTime
  scopes      String   @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Unique per user (so two users can connect the same address independently).
  @@unique([userId, provider, email])
  @@index([userId])
}

// (Self-host only) per-provider OAuth client credentials entered in-app.
// In the hosted deployment a single central client is configured via env vars
// and this table is unused.
model ProviderCredential {
  provider     String   @id // "google" | "microsoft"
  clientId     String // encrypted (AES-256-GCM)
  clientSecret String // encrypted (AES-256-GCM)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
