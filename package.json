{
  "name": "onepane",
  "version": "0.1.0",
  "private": false,
  "description": "All your email inboxes and calendars in one local-first pane. Read mail across every account, compose/reply from any of them, and send calendar invites with Google Meet, Microsoft Teams, or a physical location linked to Google Maps.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 6969",
    "build": "next build",
    "start": "next start -p 6969",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "setup": "prisma generate && prisma db push",
    "db:studio": "prisma studio",
    "service:install": "bash scripts/service-install.sh",
    "service:uninstall": "bash scripts/service-uninstall.sh",
    "service:status": "bash scripts/service-status.sh",
    "service:restart": "bash scripts/service-restart.sh",
    "service:rebuild": "bash scripts/service-restart.sh --rebuild",
    "service:logs": "tail -f \"$HOME/Library/Logs/onepane.log\"",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ical.js": "^2.2.1",
    "imapflow": "^1.3.3",
    "lucide-react": "^0.469.0",
    "mailparser": "^3.9.8",
    "next": "15.5.18",
    "nodemailer": "^8.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^1.7.1",
    "swr": "^2.3.0",
    "tailwind-merge": "^2.6.0",
    "tsdav": "^2.2.2"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.10.6",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.1",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.3"
  }
}
